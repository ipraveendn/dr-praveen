generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String    @unique
  password  String
  role      String    @default("USER")
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamp(6)
}

model Clinic {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @unique
  address   String
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  tokens    Token[]
}

model Patient {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  phone      String    @unique
  email      String?
  place      String?
  patientId  String?   @unique
  age        Int?
  gender     String?
  reason     String?
  clinicId   String?   @db.Uuid
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  clinicName String?
  tokens     Token[]

  @@index([phone], map: "idx_patient_phone")
}

model Token {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenNumber      Int
  status           TokenStatus @default(WAITING)
  reasonForVisit   String
  createdAt        DateTime?   @default(now()) @db.Timestamp(6)
  updatedAt        DateTime?   @default(now()) @updatedAt @db.Timestamp(6)
  clinicId         String      @db.Uuid
  patientId        String      @db.Uuid
  reason           String?
  appointmentDate  DateTime?   @db.Timestamp(6)
  consultationMode String?
  clinic           Clinic      @relation(fields: [clinicId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient          Patient     @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tokenNumber, appointmentDate], map: "unique_daily_token")
  @@index([clinicId(sort: Desc), appointmentDate(sort: Desc)], map: "idx_token_clinic_appointmentdate")
}

enum TokenStatus {
  WAITING
  SERVING
  COMPLETED
  CANCELLED
}

model PharmacyRequest {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prescriptionPath String?   @map("prescription_path")
  customization    String?
  status           String    @default("Pending")
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("pharmacy_requests")
}
